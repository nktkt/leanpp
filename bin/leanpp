#!/usr/bin/env python3
"""leanpp: top-level CLI for the Lean++ proof-engineering layer.

Subcommands:
  new PROJECT_NAME            Scaffold a new Lean++ project.
  transpile FILE [-o OUT]     Lower a .leanpp file to .lean.
  transpile-all [DIR]         Recursively transpile every .leanpp under DIR (default: cwd).
  build                       transpile-all + lake build.
  trust [TARGET]              Print a trust ledger.
  obligations                 List unsolved obligations / `sorry`-stubbed theorems.
  --version, --help
"""

from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path


VERSION = "0.1.0-mvp"

# Directory containing this script (resolved through symlinks).
SCRIPT_DIR = Path(__file__).resolve().parent
TRANSPILER = SCRIPT_DIR / "leanpp-transpile"


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def find_lake() -> str | None:
    """Find a usable `lake` binary, or return None."""
    p = shutil.which("lake")
    if p:
        return p
    fallback = "/Users/naoki/.elan/bin/lake"
    if os.path.exists(fallback):
        return fallback
    return None


def find_transpiler() -> Path:
    if TRANSPILER.exists():
        return TRANSPILER
    # fall back to PATH
    found = shutil.which("leanpp-transpile")
    if found:
        return Path(found)
    print(
        "leanpp: error: leanpp-transpile not found next to this script or on PATH",
        file=sys.stderr,
    )
    sys.exit(1)


def run_transpiler(in_path: Path, out_path: Path | None = None) -> int:
    transpiler = find_transpiler()
    cmd = [sys.executable, str(transpiler), str(in_path)]
    if out_path is not None:
        cmd += ["-o", str(out_path)]
    return subprocess.call(cmd)


def transpile_all(root: Path) -> int:
    """Transpile every .leanpp file under `root`. Returns count transpiled."""
    count = 0
    for path in sorted(root.rglob("*.leanpp")):
        # skip anything under build/.lake directories
        if any(part in (".lake", "build", "__pycache__") for part in path.parts):
            continue
        # Use `.transpiled.lean` so generated outputs match the project
        # `.gitignore` and don't collide with hand-written `.lean` files.
        out = path.with_suffix(".transpiled.lean")
        rc = run_transpiler(path, out)
        if rc != 0:
            print(f"leanpp: transpile failed for {path}", file=sys.stderr)
            return -1
        count += 1
    return count


# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

NEW_LAKEFILE = """\
import Lake
open Lake DSL

package «{pkg}» where

require LeanPP from "../leanpp"

@[default_target]
lean_lib «{lib}» where
  globs := #[.andSubmodules `{lib}]
"""

NEW_TOOLCHAIN = "leanprover/lean4:v4.30.0-rc2\n"

NEW_MAIN_LEANPP = """\
-- Main.leanpp -- entry point for {pkg}
-- Edit me. Lean++ source files use the `.leanpp` extension and are transpiled
-- to `.lean` (suffixed `.transpiled.lean`) automatically by `leanpp build`.

#profile research

-- A trivially-verified `abs` over `Int`. The `auto` portfolio closes
-- the postcondition without help.
spec def myAbs (x : Int) : Nat
  ensures result >= 0
by
  implementation
    if x < 0 then Int.natAbs (-x) else Int.natAbs x
  proof
    auto

-- Trust-ledger snapshot for this module. Switch `#profile` to `safe`
-- and run `leanpp build` to enforce sorry/unsafe-free CI.
#trust myAbs
"""

NEW_GITIGNORE = """\
.lake/
build/
*.olean
*.transpiled.lean
__pycache__/
"""


def cmd_new(args: argparse.Namespace) -> int:
    project = Path(args.project_name)
    if project.exists():
        print(f"leanpp new: refusing to overwrite existing path: {project}", file=sys.stderr)
        return 1
    pkg = project.name
    lib = "".join(part.capitalize() for part in re.split(r"[-_]", pkg) if part) or "Main"
    project.mkdir(parents=True)
    (project / "lakefile.lean").write_text(NEW_LAKEFILE.format(pkg=pkg, lib=lib), encoding="utf-8")
    (project / "lean-toolchain").write_text(NEW_TOOLCHAIN, encoding="utf-8")
    (project / "Main.leanpp").write_text(NEW_MAIN_LEANPP.format(pkg=pkg), encoding="utf-8")
    (project / ".gitignore").write_text(NEW_GITIGNORE, encoding="utf-8")
    print(f"leanpp new: created project {project}/")
    print(f"  next steps:")
    print(f"    cd {project}")
    print(f"    leanpp build")
    return 0


def cmd_transpile(args: argparse.Namespace) -> int:
    in_path = Path(args.file)
    out_path = Path(args.output) if args.output else None
    return run_transpiler(in_path, out_path)


def cmd_transpile_all(args: argparse.Namespace) -> int:
    root = Path(args.dir) if args.dir else Path.cwd()
    n = transpile_all(root)
    if n < 0:
        return 1
    print(f"leanpp: transpiled {n} .leanpp file(s) under {root}")
    return 0


def cmd_build(args: argparse.Namespace) -> int:
    n = transpile_all(Path.cwd())
    if n < 0:
        return 1
    print(f"leanpp: transpiled {n} .leanpp file(s)")
    lake = find_lake()
    if lake is None:
        print(
            "leanpp build: lake not found. Install Lean 4 (e.g. via elan) and re-run.",
            file=sys.stderr,
        )
        return 2
    rc = subprocess.call([lake, "build"])
    return rc


# ---- trust ledger ---------------------------------------------------------

# Crude but effective heuristics for an MVP trust scan.
RE_SORRY = re.compile(r"\bsorry\b")
RE_AXIOM = re.compile(r"^\s*axiom\s+([A-Za-z_][A-Za-z0-9_'.]*)", re.MULTILINE)
RE_UNSAFE = re.compile(r"\bunsafe\b")
RE_EXTERN = re.compile(r"@\[\s*extern\b")
RE_OBLIGATION = re.compile(r"--\s*@obligation\b|#obligation\b")
RE_PROFILE_OPT = re.compile(
    r"set_option\s+leanpp\.profile\s+([A-Za-z_][A-Za-z0-9_]*)\s+true"
)


def scan_lean_files(root: Path) -> dict:
    counts = {"sorry": 0, "unsafe": 0, "extern": 0}
    axioms: list[str] = []
    obligations_total = 0
    obligations_solved = 0
    profile: str | None = None
    for path in root.rglob("*.lean"):
        if any(part in (".lake", "build") for part in path.parts):
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        # strip line comments to avoid double-counting in `-- sorry` etc.
        # but keep `-- @obligation` tags that we explicitly look for.
        stripped_lines = []
        for raw in text.splitlines():
            # don't strip the obligation marker
            if "@obligation" in raw or "#obligation" in raw:
                stripped_lines.append(raw)
                continue
            idx = raw.find("--")
            stripped_lines.append(raw if idx < 0 else raw[:idx])
        stripped = "\n".join(stripped_lines)

        counts["sorry"] += len(RE_SORRY.findall(stripped))
        counts["unsafe"] += len(RE_UNSAFE.findall(stripped))
        counts["extern"] += len(RE_EXTERN.findall(stripped))
        for m in RE_AXIOM.finditer(stripped):
            axioms.append(m.group(1))

        for line in text.splitlines():
            if RE_OBLIGATION.search(line):
                obligations_total += 1
                # solved iff the line/file does NOT contain `sorry` shortly after
                # heuristic only -- MVP
                if "sorry" not in line:
                    obligations_solved += 1

        if profile is None:
            pm = RE_PROFILE_OPT.search(text)
            if pm:
                profile = pm.group(1)

    counts["axioms"] = axioms
    counts["obligations_total"] = obligations_total
    counts["obligations_solved"] = obligations_solved
    counts["profile"] = profile or "default"
    return counts


def _run_with_appended_commands(
    leanpp_file: Path, commands: list[str]
) -> int:
    """Transpile `leanpp_file` to a temp .lean, append the given Lean
    commands, and run `lake env lean` on it from cwd. Stdout/stderr
    stream through to the parent. Returns the lean exit code.

    This is the env-walk path: the appended `#trust` / `#obligations` /
    `#laws` commands inspect the actual elaborated environment rather
    than grepping source text. Requires a working lake (the user's
    project must `require LeanPP` so the macros are in scope)."""
    lake = find_lake()
    if lake is None:
        print(
            "leanpp: lake not found on PATH; falling back to source scan",
            file=sys.stderr,
        )
        return -1

    import tempfile
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".lean", delete=False, encoding="utf-8"
    ) as tmp:
        tmp_path = Path(tmp.name)
    try:
        rc = run_transpiler(leanpp_file, tmp_path)
        if rc != 0:
            return rc
        with tmp_path.open("a", encoding="utf-8") as fh:
            fh.write("\n-- leanpp CLI: appended diagnostic commands\n")
            for c in commands:
                fh.write(c + "\n")
        return subprocess.call([lake, "env", "lean", str(tmp_path)])
    finally:
        try:
            tmp_path.unlink()
        except OSError:
            pass


def cmd_trust(args: argparse.Namespace) -> int:
    target: str | None = args.target

    # Env-walk path: target is a .leanpp file. Run `#trust` (and
    # optionally `#trust IDENT`) against its elaborated environment.
    if target and target.endswith(".leanpp"):
        leanpp_file = Path(target)
        if not leanpp_file.exists():
            print(f"leanpp trust: {leanpp_file} not found", file=sys.stderr)
            return 1
        commands = ["#trust"]
        if args.ident:
            commands.append(f"#trust {args.ident}")
        return _run_with_appended_commands(leanpp_file, commands)

    # Source-scan fallback: walk every .lean / .leanpp file from cwd
    # and print a grep-based summary. Useful when lake/elan is not
    # installed or when we just want a fast project-wide overview.
    root = Path.cwd()
    info = scan_lean_files(root)
    axioms = info["axioms"]
    n_unsolved = max(0, info["obligations_total"] - info["obligations_solved"])
    axiom_summary = ", ".join(axioms[:4]) if axioms else "Classical.choice, Quot.sound, propext"
    if len(axioms) > 4:
        axiom_summary += ", ..."
    label = target or root.name
    print(f"Trust Ledger: {label}  (source scan; pass FILE.leanpp for env walk)")
    print(f"  kernel:    Lean 4 (unmodified)")
    print(f"  axioms:    {len(axioms) if axioms else 3} ({axiom_summary})")
    print(f"  sorry:     {info['sorry']}")
    print(f"  unsafe:    {info['unsafe']}")
    print(f"  extern:    {info['extern']}")
    print(
        f"  obligations: {info['obligations_total']} total, "
        f"{info['obligations_solved']} solved, {n_unsolved} unsolved"
    )
    print(f"Profile: {info['profile']}")
    return 0


def cmd_obligations(args: argparse.Namespace) -> int:
    target: str | None = getattr(args, "file", None)

    # Env-walk path: run `#obligations` (and `#laws`) against the
    # elaborated env of one .leanpp file.
    if target and target.endswith(".leanpp"):
        leanpp_file = Path(target)
        if not leanpp_file.exists():
            print(f"leanpp obligations: {leanpp_file} not found", file=sys.stderr)
            return 1
        return _run_with_appended_commands(leanpp_file, ["#obligations", "#laws"])

    # Source-scan fallback.
    root = Path.cwd()
    found: list[tuple[Path, int, str]] = []
    sorry_theorem = re.compile(
        r"^\s*(theorem|lemma|example)\s+([A-Za-z_][A-Za-z0-9_'.]*)\b.*?:=\s*by\s+sorry\b"
    )
    obligation_marker = re.compile(r"--\s*@obligation\b|#obligation\b")
    for path in sorted(root.rglob("*.lean")):
        if any(part in (".lake", "build") for part in path.parts):
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="replace")
        except OSError:
            continue
        for i, line in enumerate(text.splitlines(), start=1):
            if sorry_theorem.search(line) or obligation_marker.search(line):
                found.append((path, i, line.rstrip()))
    if not found:
        print("leanpp obligations: no unsolved obligations found "
              "(source scan; pass FILE.leanpp for env walk).")
        return 0
    print(f"leanpp obligations: {len(found)} obligation(s) "
          f"(source scan; pass FILE.leanpp for env walk):")
    for path, lineno, line in found:
        rel = path
        try:
            rel = path.relative_to(root)
        except ValueError:
            pass
        print(f"  {rel}:{lineno}: {line.strip()}")
    return 0


def cmd_run(args: argparse.Namespace) -> int:
    """Transpile a .leanpp file and elaborate it via `lake env lean`.
    Stdout from any `#check` / `#trust` / `#obligations` / `#laws`
    commands inside the file streams through to the parent. The
    transpiled output is written to a tempfile and cleaned up on
    exit, so the source tree stays clean.

    This is the "just run it" entry point — equivalent to
    `leanpp obligations FILE.leanpp` minus the auto-appended
    diagnostic commands."""
    in_path = Path(args.file)
    if not in_path.exists():
        print(f"leanpp run: {in_path} not found", file=sys.stderr)
        return 1
    if in_path.suffix != ".leanpp":
        print(
            f"leanpp run: warning: {in_path} does not end in .leanpp",
            file=sys.stderr,
        )
    lake = find_lake()
    if lake is None:
        print("leanpp run: lake not found on PATH", file=sys.stderr)
        return 1
    import tempfile
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".lean", delete=False, encoding="utf-8"
    ) as tmp:
        tmp_path = Path(tmp.name)
    try:
        rc = run_transpiler(in_path, tmp_path)
        if rc != 0:
            return rc
        return subprocess.call([lake, "env", "lean", str(tmp_path)])
    finally:
        try:
            tmp_path.unlink()
        except OSError:
            pass


def cmd_clean(args: argparse.Namespace) -> int:
    """Remove transpiler artifacts. With `--all`, also remove lake build
    state. Always reports what it touched, never silent."""
    root = Path.cwd()
    removed: list[Path] = []

    # Always: every `*.transpiled.lean` from cwd recursively, except inside
    # .lake / build (Lake handles those; we don't manage them here).
    for path in sorted(root.rglob("*.transpiled.lean")):
        if any(part in (".lake", "build", "__pycache__") for part in path.parts):
            continue
        try:
            path.unlink()
            removed.append(path)
        except OSError as e:
            print(f"leanpp clean: could not remove {path}: {e}", file=sys.stderr)

    # `--all`: also wipe lake build state.
    if args.all:
        for d in (root / ".lake", root / "build"):
            if d.exists():
                import shutil
                try:
                    shutil.rmtree(d)
                    removed.append(d)
                except OSError as e:
                    print(f"leanpp clean: could not remove {d}: {e}", file=sys.stderr)

    if not removed:
        print("leanpp clean: nothing to remove.")
        return 0
    print(f"leanpp clean: removed {len(removed)} item(s):")
    for p in removed:
        try:
            rel = p.relative_to(root)
        except ValueError:
            rel = p
        print(f"  {rel}")
    return 0


def cmd_doctor(args: argparse.Namespace) -> int:
    """Diagnose common issues: missing toolchain, missing lakefile, LeanPP
    import path, transpiler integrity. Prints a short report and exits
    non-zero if any check fails."""
    import shutil as _shutil
    issues: list[str] = []
    notes: list[str] = []

    # 1. Tool detection.
    lake = find_lake()
    notes.append(f"lake:    {lake or '(not found)'}")
    if lake is None:
        issues.append("lake not found on PATH; install via elan or set $LAKE")

    lean = _shutil.which("lean")
    notes.append(f"lean:    {lean or '(not found)'}")
    if lean is None:
        issues.append("lean not found on PATH; elan should expose it from lean-toolchain")

    # 2. Project state.
    cwd = Path.cwd()
    has_lakefile = (cwd / "lakefile.lean").exists() or (cwd / "lakefile.toml").exists()
    notes.append(f"cwd:     {cwd}")
    notes.append(f"lakefile: {'yes' if has_lakefile else 'no'}")
    if not has_lakefile:
        notes.append("  (run `leanpp new my-proj` to scaffold one)")

    has_toolchain = (cwd / "lean-toolchain").exists()
    notes.append(f"lean-toolchain: {'yes' if has_toolchain else 'no'}")

    # 3. Transpiler integrity.
    transpiler = Path(__file__).parent / "leanpp-transpile"
    notes.append(f"leanpp-transpile: {'ok' if transpiler.exists() else '(missing)'}")
    if not transpiler.exists():
        issues.append("leanpp-transpile script not found next to leanpp")

    # 4. LeanPP reachability — only meaningful if lake + lakefile are present.
    if lake and has_lakefile:
        import tempfile, subprocess
        with tempfile.NamedTemporaryFile(
            mode="w", suffix=".lean", delete=False, encoding="utf-8"
        ) as tf:
            tf.write("import LeanPP\n#check @LeanPP.Trust.obligationAttr\n")
            probe = Path(tf.name)
        try:
            r = subprocess.run(
                [lake, "env", "lean", str(probe)],
                capture_output=True, text=True, timeout=30,
            )
            if r.returncode == 0:
                notes.append("LeanPP import: ok")
            else:
                issues.append(
                    "LeanPP import failed; ensure `require LeanPP` is in your lakefile.\n"
                    f"    {(r.stderr or r.stdout).splitlines()[0] if (r.stderr or r.stdout).strip() else ''}"
                )
        except Exception as e:
            issues.append(f"LeanPP import probe crashed: {e}")
        finally:
            try:
                probe.unlink()
            except OSError:
                pass
    else:
        notes.append("LeanPP import: skipped (no lake / lakefile)")

    # Print report.
    print("leanpp doctor")
    print("-" * 40)
    for n in notes:
        print(f"  {n}")
    if not issues:
        print("\nNo issues detected.")
        return 0
    print(f"\n{len(issues)} issue(s):")
    for i in issues:
        print(f"  - {i}")
    return 1


# ---------------------------------------------------------------------------
# argparse plumbing
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="leanpp",
        description="Lean++ proof-engineering CLI (kernel-safe; lowers to Lean 4).",
    )
    p.add_argument("--version", action="version", version=f"leanpp {VERSION}")
    sub = p.add_subparsers(dest="cmd", metavar="COMMAND")

    p_new = sub.add_parser("new", help="Scaffold a new Lean++ project")
    p_new.add_argument("project_name")
    p_new.set_defaults(func=cmd_new)

    p_tr = sub.add_parser("transpile", help="Lower a .leanpp file to .lean")
    p_tr.add_argument("file")
    p_tr.add_argument("-o", "--output", help="Output .lean file")
    p_tr.set_defaults(func=cmd_transpile)

    p_tra = sub.add_parser(
        "transpile-all",
        help="Recursively transpile every .leanpp file (default: cwd)",
    )
    p_tra.add_argument("dir", nargs="?", default=None)
    p_tra.set_defaults(func=cmd_transpile_all)

    p_b = sub.add_parser("build", help="transpile-all + lake build")
    p_b.set_defaults(func=cmd_build)

    p_t = sub.add_parser(
        "trust",
        help=(
            "Print a trust ledger. With no argument, source-scan cwd. "
            "With FILE.leanpp, run the real `#trust` env walk via lake."
        ),
    )
    p_t.add_argument(
        "target", nargs="?", default=None,
        help="Project label (source scan) or a FILE.leanpp (env walk)",
    )
    p_t.add_argument(
        "--ident", default=None,
        help="With FILE.leanpp: also run `#trust IDENT` for a focused entry",
    )
    p_t.set_defaults(func=cmd_trust)

    p_run = sub.add_parser(
        "run",
        help="Transpile and elaborate a .leanpp file in one step.",
    )
    p_run.add_argument("file", help="Path to a .leanpp source file.")
    p_run.set_defaults(func=cmd_run)

    p_o = sub.add_parser(
        "obligations",
        help=(
            "List unsolved obligations. With no argument, source-scan cwd. "
            "With FILE.leanpp, run real `#obligations` + `#laws` via lake."
        ),
    )
    p_o.add_argument(
        "file", nargs="?", default=None,
        help="Optional FILE.leanpp; without it, do a source scan",
    )
    p_o.set_defaults(func=cmd_obligations)

    p_clean = sub.add_parser(
        "clean",
        help="Remove transpiler artifacts (*.transpiled.lean). With --all, also wipe lake build state.",
    )
    p_clean.add_argument(
        "--all", action="store_true",
        help="Also remove .lake/ and build/ directories.",
    )
    p_clean.set_defaults(func=cmd_clean)

    p_doc = sub.add_parser(
        "doctor",
        help="Diagnose missing tools / project setup / LeanPP reachability.",
    )
    p_doc.set_defaults(func=cmd_doctor)

    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if not getattr(args, "cmd", None):
        parser.print_help()
        return 0
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
